server/processed_visual_hashes.json
server/extracted_league_data.json
server/ai_analysis_log.json

# ── Screenshots cache ──────────────────────────────────────────
server/testdownloadpage/

# ── Tesseract language data (large binary) ─────────────────────
*.traineddata

